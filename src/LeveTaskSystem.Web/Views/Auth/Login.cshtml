@model LeveTaskSystem.Web.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<section class="page-card auth-card">
    <h2 class="page-title">Acesso ao sistema</h2>
    <p class="page-subtitle">Entre com seu e-mail e senha para continuar.</p>
    <form method="post" class="uk-form-stacked uk-margin-top">
        <div asp-validation-summary="All" class="uk-text-danger"></div>
        <div class="uk-margin">
            <label asp-for="Email" class="uk-form-label">E-mail</label>
            <div class="uk-form-controls">
                <input asp-for="Email" class="uk-input" />
            </div>
        </div>
        <div class="uk-margin">
            <label asp-for="Password" class="uk-form-label">Senha</label>
            <div class="uk-form-controls">
                <input asp-for="Password" class="uk-input" />
            </div>
        </div>
        <button type="submit" class="uk-button uk-button-primary uk-width-1-1">Entrar</button>
    </form>
</section>
