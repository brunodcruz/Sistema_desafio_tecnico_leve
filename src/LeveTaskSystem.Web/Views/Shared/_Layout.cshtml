<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Leve Task System</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/uikit@3.21.16/dist/css/uikit.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LeveTaskSystem.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header>
            <nav class="uk-navbar-container app-navbar" uk-navbar>
                <div class="uk-navbar-left uk-padding-small">
                    <a class="uk-navbar-item brand-title" asp-controller="Home" asp-action="Index">Leve Task System</a>
                </div>
                <div class="uk-navbar-right">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <div class="uk-navbar-item app-user">@User.Identity.Name</div>
                        <div class="uk-navbar-item uk-padding-small-right">
                            <form asp-controller="Auth" asp-action="Logout" method="post">
                                <button class="uk-button uk-button-text" type="submit">Sair</button>
                            </form>
                        </div>
                    }
                </div>
            </nav>
        </header>
        <main role="main" class="uk-margin">
            @RenderBody()
        </main>
        <footer class="app-footer">
            Leve Task System
        </footer>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/uikit@3.21.16/dist/js/uikit.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/uikit@3.21.16/dist/js/uikit-icons.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
